# Neon（Postgres）の接続文字列。Vercel では Project Settings → Environment Variables にも同じ名前で登録。
# 例: postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL=

# NextAuth（ユーザー名ログイン）。本番ではランダムな長い文字列を設定してください。
NEXTAUTH_SECRET=
# 本番 URL（例: https://your-app.vercel.app）。ローカルは http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
